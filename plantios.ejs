<!DOCTYPE html>
<html>
<head>

    <title>Plantios</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="container mt-4">

    <h1 class="mb-4">
        🌱 Plantios Cadastrados
    </h1>

    <table class="table table-bordered table-striped">

        <thead class="table-success">

            <tr>
                <th>Cultura</th>
                <th>Quantidade</th>
                <th>Data Plantio</th>
                <th>Colheita Prevista</th>
                <th>Área</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>

        </thead>

        <tbody>

            <% plantios.forEach(plantio => { %>

                <tr>

                    <td>
                        <%= plantio.cultura %>
                    </td>

                    <td>
                        <%= plantio.quantidade %>
                    </td>

                    <td>
                        <%= plantio.dataPlantio %>
                    </td>

                    <td>
                        <%= plantio.dataColheitaPrevista %>
                    </td>

                    <td>
                        <%= plantio.AreaCultivo.nome %>
                    </td>

                    <td>

                        <% if (plantio.status === 'Plantado') { %>
                            🌱 Plantado
                        <% } %>

                        <% if (plantio.status === 'Em Crescimento') { %>
                            🟡 Em Crescimento
                        <% } %>

                        <% if (plantio.status === 'Colhido') { %>
                            🟢 Colhido
                        <% } %>

                    </td>

                    <td>

                        <a href="/plantios/edit/<%= plantio.id %>" class="btn btn-warning btn-sm">
                            Editar
                        </a>

                        <form
                            action="/plantios/delete/<%= plantio.id %>"
                            method="POST"
                            style="display:inline;">

                            <button
                                type="submit"
                                class="btn btn-danger btn-sm">

                                Excluir

                            </button>

                        </form>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>

</body>
</html>