<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Novo Plantio - AgroStock</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-success">

    <div class="container">

        <a class="navbar-brand" href="/">
            🌱 AgroStock
        </a>

        <div>

            <a href="/areas" class="btn btn-light btn-sm">
                Áreas
            </a>

            <a href="/plantios" class="btn btn-light btn-sm">
                Plantios
            </a>

        </div>

    </div>

</nav>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow">

                <div class="card-body">

                    <h2 class="text-center mb-4">
                        🌱 Cadastrar Plantio
                    </h2>

                    <form action="/plantios/create" method="POST">

                        <div class="mb-3">

                            <label class="form-label">
                                Cultura
                            </label>

                            <input
                                type="text"
                                name="cultura"
                                class="form-control"
                                required>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Quantidade
                            </label>

                            <input
                                type="number"
                                name="quantidade"
                                class="form-control"
                                required>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Data do Plantio
                            </label>

                            <input
                                type="date"
                                name="dataPlantio"
                                class="form-control"
                                required>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Data Prevista de Colheita
                            </label>

                            <input
                                type="date"
                                name="dataColheitaPrevista"
                                class="form-control"
                                required>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Status
                            </label>

                            <select
                                name="status"
                                class="form-select">

                                <option value="Plantado">
                                    🌱 Plantado
                                </option>

                                <option value="Em Crescimento">
                                    🟡 Em Crescimento
                                </option>

                                <option value="Colhido">
                                    🟢 Colhido
                                </option>

                            </select>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">
                                Área de Cultivo
                            </label>

                            <select
                                name="areaCultivoId"
                                class="form-select">

                                <% areas.forEach(area => { %>

                                    <option value="<%= area.id %>">
                                        <%= area.nome %>
                                    </option>

                                <% }) %>

                            </select>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-success w-100">

                            Salvar Plantio

                        </button>

                    </form>
              </div>

            </div>

        </div>

    </div>

</div>

</body>
</html>