<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Dashboard - AgroStock</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-success">

    <div class="container">

        <a class="navbar-brand" href="/dashboard?token=<%= token %>">
            🌱 AgroStock
        </a>

    </div>

</nav>

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1>
            🌱 AgroStock
        </h1>

        <p class="lead">
            Sistema de Gestão de Produção e Estoque Agrícola Comunitário
        </p>

    </div>

<% if (sucesso === 'area') { %>

    <div class="alert alert-success">
        ✅ Área cadastrada com sucesso!
    </div>

<% } %>

<% if (sucesso === 'plantio') { %>

    <div class="alert alert-success">
        ✅ Plantio cadastrado com sucesso!
    </div>

<% } %>


    <div class="row g-4">

        <div class="col-md-6">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h3>
                        🌾 Áreas de Cultivo
                    </h3>

                    <p>
                        Cadastre e gerencie áreas agrícolas.
                    </p>

                    <a
                        href="/areas/create?token=<%= token %>"
                        class="btn btn-success">

                        Cadastrar Área

                    </a>

                    <a
                        href="/areas?token=<%= token %>"
                        class="btn btn-outline-success">

                        Ver Áreas

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h3>
                        🌱 Plantios
                    </h3>

                    <p>
                        Cadastre e acompanhe os plantios.
                    </p>

                    <a
                        href="/plantios/create?token=<%= token %>"
                        class="btn btn-success">

                        Cadastrar Plantio

                    </a>

                    <a
                        href="/plantios?token=<%= token %>"
                        class="btn btn-outline-success">

                        Ver Plantios

                    </a>

                </div>

            </div>

        </div>

    </div>

    <div class="text-center mt-5">

        <a
            href="/"
            class="btn btn-secondary">

            Voltar para Home

        </a>

    </div>

</div>

</body>

</html>