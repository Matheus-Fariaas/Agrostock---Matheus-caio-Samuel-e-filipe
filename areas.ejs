<!DOCTYPE html>
<html lang="pt-BR">
<head>

    <meta charset="UTF-8">

    <title>Áreas de Cultivo</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="container mt-4">

    <h1 class="mb-4">
        🌾 Áreas de Cultivo
    </h1>

    <a href="/areas/create" class="btn btn-success mb-3">
        + Nova Área
    </a>

    <table class="table table-bordered table-striped table-hover">

        <thead class="table-success">

            <tr>

                <th>Nome</th>
                <th>Localização</th>
                <th>Tamanho (m²)</th>
                <th>Ações</th>

            </tr>

        </thead>

        <tbody>

            <% areas.forEach(area => { %>

                <tr>

                    <td>
                        <%= area.nome %>
                    </td>

                    <td>
                        <%= area.localizacao %>
                    </td>

                    <td>
                        <%= area.tamanho %>
                    </td>

                    <td>

                        <a
                            href="/areas/edit/<%= area.id %>"
                            class="btn btn-warning btn-sm">

                            Editar

                        </a>

                        <form
                            action="/areas/delete/<%= area.id %>"
                            method="POST"
                            style="display:inline;">

                            <button
                                type="submit"
                                class="btn btn-danger btn-sm">

                                Excluir

                            </button>

                        </form>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>

</body>
</html>